# Copy this file to `.env` and fill in real values.
# Never commit .env to git.

# ── Cloudflare Tunnel ──────────────────────────────────────
# Created via `cloudflared tunnel create synthex-hub` (see README).
# Looks like:  eyJhIjoiYWFhYS…<long base64 blob>
TUNNEL_TOKEN=

# ── Hub auth ───────────────────────────────────────────────
# Single bearer token shared with all workers.
# Generate one with: openssl rand -hex 32
API_TOKEN=

# ── Postgres ───────────────────────────────────────────────
POSTGRES_USER=synthex
POSTGRES_PASSWORD=
POSTGRES_DB=synthex_hub

# ── Tuning ─────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE=100
WORKER_HEARTBEAT_TIMEOUT_SECS=120

# Optional: openssl rand -base64 64
SECRET_KEY_BASE=
